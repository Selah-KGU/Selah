{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "login",
    "luna-login",
    "detail-*",
    "luna-detail-*",
    "luna-web-*",
    "kwic-login",
    "kwic-detail-*",
    "kwic-detail-*-tb",
    "kwic-detail-*-ct",
    "kwic-headless",
    "syllabus-detail-*",
    "registration",
    "registration-tb",
    "registration-ct",
    "profile-edit",
    "profile-edit-tb",
    "profile-edit-ct",
    "facility-rsv",
    "facility-rsv-tb",
    "facility-rsv-ct",
    "settings",
    "ai-result",
    "ext-*"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "notification:allow-show"
  ]
}
