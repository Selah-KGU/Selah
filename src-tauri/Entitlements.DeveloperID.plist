<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Developer ID (direct distribution) entitlements.
     NOTE: tauri.conf.json currently points to Entitlements.plist (sandboxed).
     To use Developer ID non-sandboxed signing, change bundle.macOS.entitlements
     to "Entitlements.DeveloperID.plist" in tauri.conf.json. -->
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: required for Tauri WebView JIT -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- llama.cpp Metal JIT / WebKit paths may allocate unsigned executable pages -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Bundled / third-party dylibs (sherpa-onnx, llama.cpp Metal, WebKit) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Outbound network (API calls, SSO login, model downloads) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- OAuth2 loopback redirect (Google Calendar login) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File downloads (mail attachments, Luna course materials) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- User-selected download directory via file dialog -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Real-time STT (SenseVoice) captures from the default input device -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Debug-only osascript notification fallback (ai.rs) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
