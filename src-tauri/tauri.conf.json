{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Selah",
  "version": "0.8.2",
  "identifier": "com.kgu.selah",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Selah",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://kg-course.kwansei.ac.jp https://sso.kwansei.ac.jp https://api.openai.com https://generativelanguage.googleapis.com https://*.openai.com https://api.open-meteo.com; img-src 'self' data: https://kwic.kwansei.ac.jp",
      "dangerousDisableAssetCspModification": [
        "script-src"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "関西学院大学の学生向け統合キャンパスアプリ",
    "longDescription": "Selah は関西学院大学の KG-Course・Luna LMS・KWIC・Microsoft 365 メールを一画面に統合し、時間割・成績・課題・通知を素早く確認できるデスクトップアプリです。",
    "copyright": "Copyright 2025-2026 mirai-mamori. All rights reserved.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "files": {
        "PrivacyInfo.xcprivacy": "PrivacyInfo.xcprivacy",
        "Entitlements.plist": "Entitlements.plist"
      },
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
