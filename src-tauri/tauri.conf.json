{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Selah",
  "version": "0.1.5",
  "identifier": "com.kgu.selah",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Selah",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://kg-course.kwansei.ac.jp https://sso.kwansei.ac.jp https://api.openai.com https://generativelanguage.googleapis.com https://*.openai.com https://api.open-meteo.com; img-src 'self' data: https://kwic.kwansei.ac.jp"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
