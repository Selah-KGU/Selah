<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.application-identifier</key>
    <string>4H88DC6RMN.com.kgu.selah</string>
    <key>com.apple.developer.team-identifier</key>
    <string>4H88DC6RMN</string>
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Required for OAuth2 loopback redirect (Google Calendar login) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File downloads (mail attachments, Luna course materials) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- User-selected download directory via file dialog -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Hardened Runtime: required for Tauri WebView JIT -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- llama.cpp Metal JIT / WebKit paths may allocate unsigned executable pages -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Bundled / third-party dylibs (sherpa-onnx shared, llama.cpp Metal, WebKit) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Real-time STT (SenseVoice) captures from the default input device -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Debug-only osascript notification fallback (ai.rs) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- Explicit keychain access group for login credentials -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.kgu.selah</string>
    </array>
</dict>
</plist>
