<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Required for OAuth2 loopback redirect (Google Calendar login) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File downloads (mail attachments, Luna course materials) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- User-selected download directory via file dialog -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Hardened Runtime: required for Tauri WebView JIT -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
